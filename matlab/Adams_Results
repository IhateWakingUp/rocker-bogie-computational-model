Y_adams_3 = adams_data_4(:, 2);  % Y position from first CSV (point A)
Y_adams_4 = adams_data_5(:, 2);  % Y position from second CSV (point D)
Y_rel_3 =  abs(Y_adams_3 - Y_adams_3(idx_ref));
T_4 = adams_data_4(:, 1);
[~, idx_ref_2] = min(abs(T_4 - 2));
Y_rel_3 =  abs(Y_adams_3 - Y_adams_3(idx_ref_2));
